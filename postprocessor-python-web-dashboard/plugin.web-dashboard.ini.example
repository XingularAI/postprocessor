[common]
# Logging level: DEBUG | INFO | WARNING | ERROR
log_level = INFO

[web_app]
# URL of the web app — used by the postprocessor to forward detection frames
url = http://localhost:8111

[web_server]
# Port the web app listens on (default: 8111)
port = 8111

# Number of per-second timeline buckets to keep (~13.9 h at 1 fps; max 1,000,000)
timeline_capacity = 50000

# Reservoir sample size per scatter plot (max 1,000,000)
scatter_capacity = 5000

# Path to the SQLite database file (default: same directory as the log file)
# db_path = /opt/networkoptix-metavms/mediaserver/var/nx_ai_manager/nxai_manager/etc/plugin.web-dashboard.db
